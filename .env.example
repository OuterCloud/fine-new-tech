# ── AI 服务配置（必填）──────────────────────────────────────
# 选择一个服务商，填入对应的 API Key 和 Base URL

# 方案一：硅基流动（国内直连，有免费额度）https://siliconflow.cn
API_KEY=your_siliconflow_key_here
API_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=deepseek-ai/DeepSeek-V3

# 方案二：DeepSeek（国内直连，有免费额度）https://platform.deepseek.com
# API_KEY=your_deepseek_key_here
# API_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# 方案三：Groq（免费，需能访问境外）https://console.groq.com
# API_KEY=your_groq_key_here
# API_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile

# ── 抓取数量配置（可选）────────────────────────────────────
MAX_GITHUB_REPOS=25
MAX_HN_STORIES=30

# ── GitHub Pages 发布配置（可选）────────────────────────
# Web UI 中"发布到 GitHub Pages"按钮使用此配置
GITHUB_PAGES_REPO=https://github.com/<your-username>/<your-repo>.git
# GitHub Personal Access Token（推送私有仓库或避免输入密码时填写）
# 权限需要 repo（Contents: Write）
GITHUB_TOKEN=
